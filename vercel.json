{
  "build": {
    "env": {
      "REACT_APP_DEMO": "true",
      "REACT_APP_ENV": "ipd"
    }
  },
  "buildCommand": "node scripts/build.js",
  "outputDirectory": "build",
  "framework": null,
  "rewrites": [
    { "source": "/shared-ui/:path*", "destination": "https://pm-storybook-ui-prod.tatvacare.in/:path*" },
    { "source": "/((?!shared-ui|static|icons|favicon|manifest|logo|asset-manifest).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/shared-ui/assets/(.*\\.js)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/shared-ui/assets/(.*\\.css)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
